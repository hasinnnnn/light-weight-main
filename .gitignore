# Root ignore rules for the whole repository

# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Streamlit local secrets
.streamlit/secrets.toml

# Editor / OS files
.vscode/
.idea/
.DS_Store
Thumbs.db
